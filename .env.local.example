NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# Optional: demo board — "Try Demo" links to /demo and redirects to view-only board.
# Set DEMO_BOARD_ID to the board UUID and DEMO_VIEW_TOKEN to the view share token UUID.
DEMO_BOARD_ID=
DEMO_VIEW_TOKEN=
# Optional: public URL of the app (used for OG metadata base URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
